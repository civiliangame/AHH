# Copy to .env and fill in. .env is gitignored — never commit real keys.

# xAI API key (https://console.x.ai)
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# xAI realtime voice endpoint + model. Verify these against xAI's realtime docs.
XAI_REALTIME_URL=wss://api.x.ai/v1/realtime
XAI_REALTIME_MODEL=grok-realtime

# Voice + persona
XAI_VOICE=ara
XAI_INSTRUCTIONS=You are a friendly, concise voice assistant answering a phone call. Keep replies short and natural for speech.

# Local server
HOST=0.0.0.0
PORT=5000
LOG_LEVEL=INFO
