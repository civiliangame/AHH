# Copy to .env and fill in. .env is gitignored — never commit real keys.

# xAI API key (https://console.x.ai)
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# xAI Voice Agent API endpoint + model.
# grok-voice-latest = newest; or pin grok-voice-think-fast-1.0
XAI_REALTIME_URL=wss://api.x.ai/v1/realtime
XAI_REALTIME_MODEL=grok-voice-latest

# Voice: eve, ara, rex, sal, leo, or a custom voice ID.
XAI_VOICE=ara
XAI_INSTRUCTIONS=You are Grok, a helpful voice assistant speaking to a caller in real time over the phone. Keep replies short, natural, and conversational since they are spoken aloud.

# Bot speaks first when the call connects. Leave blank to wait for the caller.
XAI_GREETING=Say hello and introduce yourself briefly.

# Outbound check-in agent (run_checkin.py) — separate persona.
CHECKIN_VOICE=rex
CHECKIN_GREETING=Hi, this is Eva from AtLegionX calling to check in. Is now a good time to talk for a couple of minutes?

# Local server
HOST=0.0.0.0
PORT=5000
LOG_LEVEL=INFO

# Telnyx Call Control (Voice API). API key starts with "KEY...".
TELNYX_API_KEY=KEYxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your public ngrok domain (no scheme), e.g. abc123.ngrok-free.app.
# Leave blank to auto-derive from the inbound webhook Host header (inbound only).
PUBLIC_HOSTNAME=
STREAM_PATH=/media-stream

# Outbound calls (run_checkin.py): Call Control App connection id + a Telnyx
# number on it to call from. Both from the Telnyx portal.
TELNYX_CONNECTION_ID=
TELNYX_FROM_NUMBER=
